{
  "name": "daily-task-updater-backend",
  "version": "1.0.0",
  "description": "Backend server for Employee Daily Task Updater",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "kill-port": "powershell -Command \"$p=(netstat -ano | findstr :5000 | findstr LISTENING | ForEach-Object { $_.Split(' ')[-1] } | Select-Object -First 1); if ($p) { taskkill /PID $p /F }\"",
    "start": "node server.js",
    "dev": "nodemon server.js || node server.js",
    "init-db": "node scripts/init-db.js",
    "seed": "node seed.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@octokit/app": "^16.1.2",
    "@octokit/rest": "^22.0.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.19.0",
    "googleapis": "^172.0.0",
    "helmet": "^8.2.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "ngrok": "^5.0.0-beta.2",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.5",
    "qrcode-terminal": "^0.12.0",
    "socket.io": "^4.8.3",
    "whatsapp-web.js": "^1.26.0",
    "xlsx": "^0.18.5"
  }
}
